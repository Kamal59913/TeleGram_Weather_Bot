{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/routes/routes.config.tsx",
    "src/layout/AppLayout.tsx",
    "src/layout/AppSidebar.tsx",
    "src/layout/AppHeader.tsx",
    "src/layout/Backdrop.tsx",
    "src/layout/AuthPageLayout.tsx",
    "src/context/SidebarContext.tsx",
    "src/redux/store.ts",
    "src/redux/provider.tsx",
    "src/redux/authThunk.ts",
    "src/redux/slices/authSlice.ts",
    "src/redux/slices/globalSlice.ts",
    "src/redux/slices/modalSlice.ts",
    "src/redux/hooks/useGlobalStates.ts",
    "src/redux/hooks/useUserData.ts",
    "src/redux/hooks/useModal.ts",
    "src/api/axiosInstance.ts",
    "src/api/clients/apiClient.ts",
    "src/api/services/authService.ts",
    "src/pages/SignIn.tsx",
    "src/components/auth/routes/AuthWrapper.tsx",
    "src/components/auth/routes/ProtectedRoute.tsx",
    "src/components/authentications/login/SignInForm.tsx",
    "src/components/authentications/login/hook/login.hook.ts",
    "src/components/authentications/login/validation/email.validator.ts",
    "src/components/dashboard/**/*.tsx",
    "src/components/subscribers/**/*.tsx",
    "src/components/weather-config/**/*.tsx",
    "src/components/settings/SettingsModule.tsx",
    "src/components/common/PageMeta.tsx",
    "src/components/common/ScrollToTop.tsx",
    "src/components/header/UserDropdown.tsx",
    "src/components/ui/dropdown/**/*.tsx",
    "src/components/ui/loader/loader.tsx",
    "src/config/**/*.ts",
    "src/utils/getToken.ts",
    "src/utils/queryClient.ts",
    "src/utils/storeClear.ts",
    "src/utils/toastService.ts",
    "src/utils/validation.ts",
    "src/vite-env.d.ts"
  ]
}
